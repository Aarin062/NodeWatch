# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- Virtual envs ---
.venv/
venv/
env/

# --- Generated artifacts / outputs (keep the dirs via .gitkeep) ---
artifacts/*
!artifacts/.gitkeep
results/*
!results/.gitkeep

# --- Data (raw + intermediate) ---
data/*
!data/processed/
data/processed/*
!data/processed/.gitkeep

# --- Serialized models / large binaries ---
*.pkl
*.joblib
*.h5
*.parquet

# --- Neo4j dumps / imports ---
*.dump
neo4j_import*/

# --- OS / editor ---
.DS_Store
.ipynb_checkpoints/

# --- Old project (read-only reference; never push) ---
reference/

# --- Claude Code local settings (personal, not shared) ---
.claude/settings.local.json

# --- Local-only assistant rulebook & working docs (kept local, not in the repo) ---
CLAUDE.md
docs/
